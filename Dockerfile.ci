# CI Dockerfile - uses pre-built binaries from cross-rs
FROM alpine:latest AS certs
RUN apk add --no-cache ca-certificates

FROM scratch

ARG TARGETARCH

COPY --from=certs /etc/ssl/certs/ca-certificates.crt /etc/ssl/certs/
COPY binaries/${TARGETARCH}/wsproxy /wsproxy

EXPOSE 8080

ENTRYPOINT ["/wsproxy"]
